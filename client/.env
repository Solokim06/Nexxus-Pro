# ============================================
# NEXXUS-PRO CLIENT ENVIRONMENT CONFIGURATION
# ============================================
# Instructions:
# 1. Copy this entire file to .env
# 2. Replace placeholder values with your actual credentials
# 3. For development, keep as is
# 4. For production, update all production values
# ============================================

# ============================================
# API Configuration
# ============================================
# For development: http://localhost:5000/api
# For production: https://api.nexxus-pro.com/api
REACT_APP_API_URL=http://localhost:5000/api

# WebSocket URL
# For development: ws://localhost:5000
# For production: wss://api.nexxus-pro.com
REACT_APP_WS_URL=ws://localhost:5000

# ============================================
# PayPal Configuration
# ============================================
# Get your Client ID from: https://developer.paypal.com
# Development (Sandbox): Use sandbox client ID
# Production: Use live client ID
REACT_APP_PAYPAL_CLIENT_ID=sb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Environment: sandbox or production
REACT_APP_PAYPAL_ENVIRONMENT=sandbox

# ============================================
# M-Pesa Configuration (Kenya)
# ============================================
# Get credentials from: https://developer.safaricom.co.ke
# Sandbox credentials are provided for testing
# Production: Replace with live credentials

# Environment: sandbox or production
REACT_APP_MPESA_ENVIRONMENT=sandbox

# Passkey (Same for sandbox and production)
REACT_APP_MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Shortcode (174379 is the sandbox shortcode)
REACT_APP_MPESA_SHORTCODE=174379

# Consumer Key (Get from Safaricom Developer Portal)
REACT_APP_MPESA_CONSUMER_KEY=YOUR_CONSUMER_KEY_HERE

# Consumer Secret (Get from Safaricom Developer Portal)
REACT_APP_MPESA_CONSUMER_SECRET=YOUR_CONSUMER_SECRET_HERE

# ============================================
# Bank Transfer Configuration
# ============================================
# Bank name for transfers
REACT_APP_BANK_NAME=KCB Bank Kenya

# Bank account name
REACT_APP_BANK_ACCOUNT_NAME=Nexxus-Pro Ltd

# Bank account number
REACT_APP_BANK_ACCOUNT_NUMBER=1234567890

# Bank branch
REACT_APP_BANK_BRANCH=Upper Hill, Nairobi

# SWIFT code
REACT_APP_BANK_SWIFT_CODE=KCBLKENX

# ============================================
# Google Analytics
# ============================================
# Get tracking ID from: https://analytics.google.com
# Format: G-XXXXXXXXXX
REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================
# Sentry Error Tracking (Optional)
# ============================================
# Get DSN from: https://sentry.io
REACT_APP_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ============================================
# Social Login (OAuth)
# ============================================
# Google OAuth - Get from: https://console.cloud.google.com
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# GitHub OAuth - Get from: https://github.com/settings/developers
REACT_APP_GITHUB_CLIENT_ID=your-github-client-id

# Facebook OAuth - Get from: https://developers.facebook.com
REACT_APP_FACEBOOK_APP_ID=your-facebook-app-id

# ============================================
# Google reCAPTCHA
# ============================================
# Get keys from: https://www.google.com/recaptcha
REACT_APP_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI

# ============================================
# Feature Flags
# ============================================
# Enable/disable features (true/false)
REACT_APP_ENABLE_MPESA=true
REACT_APP_ENABLE_PAYPAL=true
REACT_APP_ENABLE_BANK_TRANSFER=true
REACT_APP_ENABLE_SOCIAL_LOGIN=true
REACT_APP_ENABLE_FILE_PREVIEW=true
REACT_APP_ENABLE_CHUNK_UPLOAD=true
REACT_APP_ENABLE_2FA=false

# ============================================
# Application Settings
# ============================================
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0
REACT_APP_NAME=Nexxus-Pro
REACT_APP_DOMAIN=localhost:3000
REACT_APP_SUPPORT_EMAIL=support@nexxus-pro.com
REACT_APP_SUPPORT_PHONE=+254700000000

# ============================================
# File Upload Limits (in bytes)
# ============================================
# 1 MB = 1048576 bytes
# 10 MB = 10485760 bytes
# 50 MB = 52428800 bytes
# 100 MB = 104857600 bytes
# 500 MB = 524288000 bytes

# Maximum file size per upload (default: 100MB)
REACT_APP_MAX_FILE_SIZE=104857600

# Chunk size for large files (default: 5MB)
REACT_APP_MAX_CHUNK_SIZE=5242880

# Maximum concurrent uploads (default: 3)
REACT_APP_MAX_CONCURRENT_UPLOADS=3

# ============================================
# Performance & Caching
# ============================================
REACT_APP_CACHE_VERSION=v1
REACT_APP_OFFLINE_MODE=true
REACT_APP_PWA_ENABLED=true

# ============================================
# Maintenance Mode
# ============================================
# Set to true when doing maintenance
REACT_APP_MAINTENANCE_MODE=false
REACT_APP_MAINTENANCE_MESSAGE="We're currently undergoing maintenance. Please check back soon."

# ============================================
# Debug Settings
# ============================================
# Enable debug logging (true/false)
REACT_APP_DEBUG_MODE=true

# Log level: debug, info, warn, error
REACT_APP_LOG_LEVEL=debug

# ============================================
# Quick Setup Guide
# ============================================
# 
# FOR DEVELOPMENT (Local):
# 1. Keep REACT_APP_API_URL=http://localhost:5000/api
# 2. Keep REACT_APP_MPESA_ENVIRONMENT=sandbox
# 3. Keep REACT_APP_PAYPAL_ENVIRONMENT=sandbox
# 4. Set REACT_APP_DEBUG_MODE=true
# 5. No real credentials needed for sandbox testing
#
# FOR PRODUCTION (Live):
# 1. Change REACT_APP_API_URL to https://api.yourdomain.com/api
# 2. Change REACT_APP_MPESA_ENVIRONMENT=production
# 3. Update REACT_APP_MPESA_CONSUMER_KEY and _SECRET with live keys
# 4. Change REACT_APP_PAYPAL_ENVIRONMENT=production
# 5. Update REACT_APP_PAYPAL_CLIENT_ID with live client ID
# 6. Set REACT_APP_DEBUG_MODE=false
# 7. Set REACT_APP_ENV=production
# 8. Update REACT_APP_DOMAIN to your production domain
# ============================================