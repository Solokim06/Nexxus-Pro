# ============================================
# NEXUS-PRO ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update values
# ============================================

# Application
NODE_ENV=development
APP_NAME=Nexxus-Pro
APP_VERSION=2.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# Server
PORT=5000
HOST=localhost

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexxus_pro
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexxus_pro

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-this-to-a-secure-secret-in-production
JWT_REFRESH_SECRET=change-this-to-a-secure-refresh-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage
STORAGE_URL=http://localhost:5000/storage
MAX_FILE_SIZE=104857600
MAX_CHUNK_SIZE=5242880

# AWS S3 (if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=nexxus-pro-storage

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@nexxus-pro.com
SMTP_PASS=
SMTP_FROM=noreply@nexxus-pro.com
SMTP_FROM_NAME=Nexxus-Pro

# M-Pesa
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_SHORTCODE=174379
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=

# PayPal
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Bank Transfer
BANK_NAME=KCB Bank Kenya
BANK_ACCOUNT_NAME=Nexxus-Pro Ltd
BANK_ACCOUNT_NUMBER=1234567890
BANK_BRANCH=Upper Hill, Nairobi
BANK_SWIFT_CODE=KCBLKENX
BANK_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# CORS
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=change-this-session-secret

# Features
ENABLE_MPESA=true
ENABLE_PAYPAL=true
ENABLE_BANK_TRANSFER=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_CHUNK_UPLOAD=true

# Backup
BACKUP_DIR=./backups
MAX_BACKUPS=10

# Monitoring
SENTRY_DSN=
HEALTH_CHECK_PATH=/health