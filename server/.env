# ============================================
# NEXUS-PRO SERVER ENVIRONMENT CONFIGURATION
# ============================================

# Server Configuration
NODE_ENV=production
PORT=5000
API_URL=https://api.nexxus-pro.com
CLIENT_URL=https://nexxus-pro.com

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/nexxus_pro
# For production with authentication:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexxus_pro?retryWrites=true&w=majority

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production

# Storage Configuration
STORAGE_TYPE=local  # local or s3
STORAGE_PATH=./storage
STORAGE_URL=http://localhost:5000/storage

# AWS S3 Configuration (if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=nexxus-pro-storage

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@nexxus-pro.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@nexxus-pro.com
SMTP_FROM_NAME=Nexxus-Pro

# M-Pesa Configuration
MPESA_ENVIRONMENT=sandbox  # sandbox or production
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_SHORTCODE=174379
MPESA_INITIATOR_NAME=testapi
MPESA_SECURITY_CREDENTIAL=your_security_credential

# PayPal Configuration
PAYPAL_ENVIRONMENT=sandbox  # sandbox or production
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Bank Transfer Configuration
BANK_NAME=KCB Bank Kenya
BANK_ACCOUNT_NAME=Nexxus-Pro Ltd
BANK_ACCOUNT_NUMBER=1234567890
BANK_BRANCH=Upper Hill, Nairobi
BANK_SWIFT_CODE=KCBLKENX
BANK_SORT_CODE=010000
BANK_WEBHOOK_SECRET=your_bank_webhook_secret

# Feature Flags
ENABLE_MPESA=true
ENABLE_PAYPAL=true
ENABLE_BANK_TRANSFER=true
ENABLE_SOCIAL_LOGIN=true

# File Upload Limits
MAX_FILE_SIZE=104857600  # 100MB
MAX_CHUNK_SIZE=5242880   # 5MB
MAX_CONCURRENT_UPLOADS=3

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Backup Configuration
BACKUP_DIR=./backups
MAX_BACKUPS=10

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://nexxus-pro.com

# Session Configuration
SESSION_SECRET=your-session-secret-change-this
SESSION_MAX_AGE=86400000  # 24 hours

# Security
BCRYPT_ROUNDS=12
CORS_CREDENTIALS=true

# Monitoring
SENTRY_DSN=your_sentry_dsn
NEW_RELIC_LICENSE_KEY=your_newrelic_key

# Development only
DEBUG_MODE=false